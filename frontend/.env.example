# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local overrides.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Base URL of the deployed backend (no trailing slash, no /graphql)
# Default (when unset): http://localhost:4000
# In production (Vercel): set this to your Render service URL
VITE_API_URL=https://your-backend.onrender.com
