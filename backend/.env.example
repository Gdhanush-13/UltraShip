# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env for local overrides.
# None of these are required locally — defaults work out of the box.

# Port the Express server listens on (Render sets this automatically)
PORT=4000

# Node environment — controls error verbosity and Apollo stack traces
# Values: development | production
NODE_ENV=development

# Allowed frontend origin(s) for CORS.
# Use * to allow all origins (default, fine for local dev).
# In production set to your Vercel URL.
# Comma-separate multiple origins: https://a.vercel.app,https://b.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app
